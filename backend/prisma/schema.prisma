datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  CANDIDATE
  RECRUITER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum AttributeType {
  STRING
  TEXT
  IMAGE
  NUMERIC
  DATE
  PERIOD
  BOOLEAN
  DROPDOWN
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  role      Role       @default(CANDIDATE)
  status    UserStatus @default(ACTIVE)
  version   Int        @default(1)
  profile   Profile?
  cvs       CV[]
  comments  Comment[]
  likes     Like[]
}

model Profile {
  id              String                 @id @default(uuid())
  userId          String                 @unique
  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName       String
  lastName        String
  location        String
  photoUrl        String
  version         Int                    @default(1)
  attributeValues ProfileAttributeValue[]
  projects        Project[]
}

model AttributeLibrary {
  id               String                 @id @default(uuid())
  category         String
  name             String                 @unique
  description      String
  type             AttributeType
  version          Int                    @default(1)
  positionRelation PositionAttribute[]
  profileValues    ProfileAttributeValue[]
}

model Position {
  id               String              @id @default(uuid())
  title            String
  description      String
  accessRules      Json
  maxProjects      Int                 @default(3)
  version          Int                 @default(1)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  attributes       PositionAttribute[]
  cvs              CV[]
  comments         Comment[]
}

model PositionAttribute {
  id          String           @id @default(uuid())
  positionId  String
  position    Position         @relation(fields: [positionId], references: [id], onDelete: Cascade)
  attributeId String
  attribute   AttributeLibrary @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  isRequired  Boolean          @default(false)

  @@unique([positionId, attributeId])
}

model ProfileAttributeValue {
  id          String           @id @default(uuid())
  profileId   String
  profile     Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  attributeId String
  attribute   AttributeLibrary @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value       String

  @@unique([profileId, attributeId])
}

model Project {
  id          String   @id @default(uuid())
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name        String
  startDate   DateTime
  endDate     DateTime
  description String
  tags        String[]
}

model CV {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  positionId String
  position   Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  isPublished Boolean  @default(false)
  version    Int      @default(1)
  createdAt  DateTime @default(now())
  likes      Like[]

  @@unique([userId, positionId])
}

model Comment {
  id         String   @id @default(uuid())
  positionId String
  position   Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content    String
  createdAt  DateTime @default(now())
}

model Like {
  id     String @id @default(uuid())
  cvId   String
  cv     CV     @relation(fields: [cvId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cvId, userId])
}